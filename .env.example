# Telegram API Credentials (Get from my.telegram.org)
API_ID=your_api_id
API_HASH=your_api_hash
PHONE_NUMBER=+998901234567

# session string (will be generated by generateSession.js)
STRING_SESSION=

# Database Configuration (PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=telegram_leads
DB_PASSWORD=your_password
DB_PORT=5432

# Bot Logic Configuration
ADMIN_ID=123456789
# Comma separated values
KEYWORDS=sotaman,olaman,zakaz,buyurtma,service
STOP_WORDS=reklama,spam,bot
# Comma separated chat IDs or usernames (e.g. -100123456789,@groupname)
TARGET_CHAT_IDS=-100123456789,@uz_it_jobs
